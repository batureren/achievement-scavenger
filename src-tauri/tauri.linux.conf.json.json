{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AchievementScavenger",
  "version": "0.1.6",
  "identifier": "com.sawwormgames.achievement-scavenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Achievement Scavenger: Tracker & Guides",
        "width": 800,
        "height": 600,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
"bundle": {
    "createUpdaterArtifacts": true,
    "publisher": "sawworm Games",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "active": true,
    "targets": [
      "nsis",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/batureren/achievement-scavenger/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyMzY5QkI0QTBFM0FDNzMKUldSenJPT2d0SnMyc3U3eWhxOHJsYm0rRnFCaDRsUGN0bGFBU2JOOTFNQXg4ME0xU1BUWnNpRVEK"
    }
  }
}